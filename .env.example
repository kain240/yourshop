# ── Local Development ──────────────────────────────────────────────
# Copy this file to .env and fill in your values

# Flask
SECRET_KEY=change-this-to-a-long-random-string
FLASK_ENV=development

# Database (choose one)

# Option A: Full URL (Railway/Render style)
# DATABASE_URL=mysql+pymysql://user:password@host:3306/yourshop

# Option B: Individual vars (easier for local dev)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=yourshop

# Email (Gmail example — use App Password, not real password)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_DEFAULT_SENDER=YourShop <your@gmail.com>

# Upload folder (leave blank to use default)
# UPLOAD_FOLDER=/tmp/yourshop_uploads
